# BOT_DATA
BOT_TOKEN={{ token }}

{% if mode.type == 'webhook' %}
# WEBHOOK_DATA
WEBHOOK_URL={{ mode.data.host }}
WEBHOOK_PORT={{ mode.data.port }}
WEBHOOK_PATH={{ mode.data.url_path }}
WEBHOOK_SECRET={{ mode.data.webhook_secret }}

{% endif %}
{% if database.name == 'postgresql' %}
# DATABASE_DATA
POSTGRES_HOST={{ database.data.host }}
POSTGRES_PORT={{ database.data.port }}
POSTGRES_USER={{ database.data.user }}
POSTGRES_PASSWORD={{ database.data.password }}
POSTGRES_NAME={{ database.data.name_database }}
DEBUG=False

{% endif %}
{% if database.name == 'aiosqlite' %}
# DATABASE_DATA
NAME_DATABASE={{ database.data.name_database }}
DEBUG=False
{% endif %}